# Set the timezone for the application. This should match the TZ variable in docker-compose.yml.
# For a list of valid timezones: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Istanbul

# DEBUG, INFO, WARNING, ERROR or CRITICAL
LOGGING_LEVEL=DEBUG

# Optional: Automatically delete video files from Google Drive older than this many days.
# Set to 0 to disable automatic deletion.
GDRIVE_RETENTION_DAYS=0

# Optional: How long to keep events in the local SQLite DB, regardless of whether
# they were uploaded or not. After this period the row is deleted (the file in
# Google Drive is not affected - it stays there). Should be safely larger than
# your Frigate clip retention (typically 14 days). Default: 30 days.
# Legacy variables EVENT_RETENTION_DAYS and STALE_PENDING_DAYS are still
# respected as fallbacks for backwards compatibility.
DB_RETENTION_DAYS=30

# Optional: After how many failed upload attempts an event is marked as
# non-retriable (retry=0). At a 10-minute retry interval, 50 attempts equal
# about 8 hours of trying. After that the event is no longer touched but stays
# in the DB until DB_RETENTION_DAYS deletes it. Default: 50.
MAX_RETRY_ATTEMPTS=50

# Optional: Maximum clip size to upload. Human-readable values like 5GB, 500MB.
# Clips larger than this are skipped immediately (marked as non-retriable).
# Set to 0 or leave empty to disable the limit.
MAX_CLIP_SIZE=5GB

# Optional: Skip events whose duration (end_time - start_time) exceeds this
# number of seconds. Useful as a complement to MAX_CLIP_SIZE: catches long
# but low-bitrate events (e.g. a 5h "stationary object" clip that ends up at
# 1.5 GB and would slip past MAX_CLIP_SIZE=5GB). Also avoids the expensive
# Frigate clip-assembly roundtrip on the /clip.mp4 endpoint, which can hang
# for minutes on very long events. Value is in seconds. Set to 0 or leave
# empty to disable. Example: 14400 = 4h.
SKIP_EVENTS_LONGER_THAN_SECONDS=0

# MQTT
MQTT_BROKER_ADDRESS=192.168.0.59
MQTT_TOPIC=frigate/events
MQTT_USER=username
MQTT_PORT=1883
MQTT_PASSWORD=secret


# Google Drive
SERVICE_ACCOUNT_FILE=credentials/service_account.json
GOOGLE_ACCOUNT_TO_IMPERSONATE=myexamplemail@gmail.com

# Upload directory in Google Drive, will be created automatically in Google Drive. It will be created under the root directory.
# Directory structure in Google Drive will be: /<UPLOAD_DIR>/<YEAR>/<MONTH>/<DAY>/
UPLOAD_DIR=frigate


# Frigate URL with protocol and port
FRIGATE_URL=http://192.168.0.100:5000


# Mattermost
MATTERMOST_WEBHOOK_URL=
MATTERMOST_PREFIX="[my message prefix]"

# Optional: Time of day for the Daily Health Report (24h format HH:MM, container
# timezone — see TZ above). Default: 09:00. Invalid values fall back to 09:00.
HEALTH_REPORT_TIME=09:00

# Optional: When `true`, the Daily Health Report only posts to Mattermost when
# there is a WARNING or CRITICAL condition. OK-reports are silently logged
# instead. Default: false (always post). Accepts true/false, yes/no, 1/0, on/off.
HEALTH_REPORT_ONLY_ON_ISSUES=false